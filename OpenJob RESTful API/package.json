{
  "name": "openjob-restful-api",
  "version": "1.0.0",
  "description": "RESTful API dasar untuk aplikasi rekrutmen OpenJob.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "nodemon src/server.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "migrate:create": "node-pg-migrate create",
    "lint": "node scripts/check-syntax.js"
  },
  "keywords": [
    "express",
    "postgresql",
    "openjob",
    "restful-api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.8",
    "pg": "^8.13.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
